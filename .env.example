# Enable the live WhatsApp integration test module.
# Accepted truthy values: 1, true, TRUE, yes, on
RUN_LIVE_WHATSAPP_TESTS=false

# Amarula profile name used by the live listener/transport.
WHATSAPP_PROFILE=jido_chat_whatsapp_live

# Recipient JID for live outbound tests. Examples:
#   15551234567@s.whatsapp.net
#   120363000000000000@g.us
WHATSAPP_TEST_JID=

# Optional: recipient phone number without the WhatsApp server suffix.
# Defaults to the user part of WHATSAPP_TEST_JID.
WHATSAPP_TEST_PHONE=

# Optional: reaction emoji used by live reaction coverage.
# Defaults to thumbs-up when unset.
WHATSAPP_TEST_REACTION=

# Optional: wait for a manual reply from WHATSAPP_TEST_JID and normalize it.
WHATSAPP_WAIT_FOR_REPLY=false

# Optional local profile storage root when live testing.
WHATSAPP_STORAGE_ROOT=

# Optional live-test tuning.
WHATSAPP_OPEN_TIMEOUT_MS=30000
WHATSAPP_REPLY_TIMEOUT_MS=180000
WHATSAPP_LIVE_SEND_DELAY_MS=60000
WHATSAPP_LIVE_SEND_JITTER_MS=0
WHATSAPP_SYNC_FULL_HISTORY=false
WHATSAPP_MARK_ONLINE_ON_CONNECT=
WHATSAPP_MAX_RETRIES=0
WHATSAPP_KEEP_ALIVE_INTERVAL_MS=
